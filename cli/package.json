{
  "name": "@atlas-world/cli",
  "version": "1.0.0",
  "description": "Atlas World Protocol — CLI para crear y administrar mundos persistentes en Solana",
  "bin": {
    "atlas-cli": "./dist/index.js"
  },
  "main": "dist/index.js",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc --project tsconfig.json && cp src/idl.json dist/idl.json && chmod +x dist/index.js",
    "dev": "tsc --project tsconfig.json --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@atlas-world/core": "workspace:*",
    "@atlas-world/sdk": "workspace:*",
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.4",
    "commander": "^12.1.0",
    "inquirer": "^9.3.7",
    "chalk": "^4.1.2",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22",
    "typescript": "^5.7.3"
  },
  "license": "MIT"
}
