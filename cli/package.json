{
  "name": "@atlas-world/cli",
  "version": "1.2.0",
  "description": "Atlas World Protocol — CLI para crear y administrar mundos persistentes en Solana",
  "bin": {
    "atlas-cli": "./dist/index.js"
  },
  "main": "dist/index.js",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc --project tsconfig.json && chmod +x dist/index.js",
    "dev": "tsc --project tsconfig.json --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@atlas-world/core": "workspace:*",
    "@atlas-world/sdk": "workspace:*",
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.4",
    "commander": "^12.1.0",
    "inquirer": "^8.2.6",
    "chalk": "^4.1.2",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^22",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/usainbluntmx/atlas-sdk.git",
    "directory": "cli"
  },
  "homepage": "https://github.com/usainbluntmx/atlas-sdk#readme",
  "keywords": ["solana", "cli", "gamefi", "web3", "gaming"],
  "license": "MIT"
}
