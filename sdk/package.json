{
  "name": "@atlas-world/sdk",
  "version": "1.2.0",
  "description": "Atlas World Protocol — SDK for building persistent worlds on Solana",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc --project tsconfig.json && cp src/idl.json dist/idl.json",
    "dev": "tsc --project tsconfig.json --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@atlas-world/core": "workspace:*",
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/usainbluntmx/atlas-sdk.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/usainbluntmx/atlas-sdk#readme",
  "keywords": [
    "solana", "anchor", "gamefi", "web3", "gaming",
    "persistent-world", "blockchain", "sdk"
  ],
  "license": "MIT"
}
